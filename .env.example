# This signer's Turnkey API credentials
# Each person deploying their own signer uses their own keypair here.
TURNKEY_API_PUBLIC_KEY=
TURNKEY_API_PRIVATE_KEY=

# Shared org ID (same for all signers)
TURNKEY_ORG_ID=

# Only approve signing requests for this wallet address.
# Rejects anything targeting an unexpected wallet — prevents rogue approvals.
ALLOWED_WALLET_ADDRESS=

# Optional — defaults to https://api.turnkey.com
# TURNKEY_BASE_URL=
